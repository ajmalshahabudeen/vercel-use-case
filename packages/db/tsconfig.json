{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "5.0",
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@workspace/db": ["./src/index.ts"],
      "@workspace/db/*": ["./*"]
    }
  },
  "include": [
    "./**/*.ts",
    "src/**/*.ts",
    "generated/**/*.ts",
    "prisma.config.ts"
  ],
  "exclude": ["node_modules", "dist", "generated/prisma/runtime"]
}
